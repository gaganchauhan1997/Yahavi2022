# Copy this file to .env and fill in your real values
# NEVER commit .env to git

# Relative path — nginx on hackknow.com proxies /graphql to shop.hackknow.com.
# This keeps the subdomain hidden in the browser address bar.
VITE_WORDPRESS_URL=/graphql

VITE_RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_YOUR_KEY
