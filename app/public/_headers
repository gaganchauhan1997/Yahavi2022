# Cloudflare Pages headers — security + cache policy
# No GCE. Proxy handled by app/functions/_middleware.js (Cloudflare Workers).

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# HTML — never cache (always serve fresh index.html)
/
  Cache-Control: no-store, must-revalidate
/index.html
  Cache-Control: no-store, must-revalidate

# Hashed JS/CSS bundles — immutable forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts — immutable forever
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# WordPress REST API — never cache
/wp-json/*
  Cache-Control: no-store

# WPGraphQL — never cache
/graphql
  Cache-Control: no-store

# WordPress uploads/media — short cache
/wp-content/*
  Cache-Control: public, max-age=86400
